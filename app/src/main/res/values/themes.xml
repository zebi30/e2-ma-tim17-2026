<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. Forced Light so hardcoded white backgrounds
         never get near-white Material text on top of them. -->
    <style name="Base.Theme.MyApplication" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/primary</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Surfaces / backgrounds -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/background</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:editTextColor">@color/text_primary</item>

        <!-- Controls (cursor, focused outline) -->
        <item name="colorControlActivated">@color/primary</item>
        <item name="colorControlNormal">@color/text_secondary</item>

        <!-- Default outlined text field style for consistent, readable boxes -->
        <item name="textInputStyle">@style/AppTextInput</item>
    </style>

    <style name="AppTextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="boxStrokeWidth">1dp</item>
    </style>

    <style name="Theme.MyApplication" parent="Base.Theme.MyApplication" />
</resources>
