<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/back_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="@string/back_arrow"
            android:textSize="24sp"
            android:textColor="@color/primary"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/notifications"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:paddingStart="16dp" />

    </LinearLayout>

    <!-- Filter Buttons -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/filter_all"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="@string/all"
                android:paddingHorizontal="16dp"
                android:textColor="@color/white"
                android:backgroundTint="@color/primary"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/filter_chat"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="@string/chat"
                android:paddingHorizontal="16dp"
                android:backgroundTint="@color/background"
                android:textColor="@color/text_primary"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/filter_ranking"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="@string/ranking"
                android:paddingHorizontal="16dp"
                android:backgroundTint="@color/background"
                android:textColor="@color/text_primary"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/filter_rewards"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="@string/rewards"
                android:paddingHorizontal="16dp"
                android:backgroundTint="@color/background"
                android:textColor="@color/text_primary"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/filter_read"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="@string/filter_read"
                android:paddingHorizontal="16dp"
                android:backgroundTint="@color/background"
                android:textColor="@color/text_primary" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- Send test notification button -->
    <Button
        android:id="@+id/send_test_notification"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:text="@string/send_test_notification_button"
        android:backgroundTint="@color/primary"
        android:textColor="@color/white" />

    <!-- Notifications List -->
    <ListView
        android:id="@+id/notifications_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@color/divider"
        android:dividerHeight="1dp" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no_notifications"
            android:textSize="18sp"
            android:textColor="@color/text_secondary" />

    </LinearLayout>

</LinearLayout>





