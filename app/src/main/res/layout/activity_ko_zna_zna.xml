<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/quit_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="@string/close_symbol"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/ko_zna_zna"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/time_label"
                android:textSize="12sp"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/time_5s"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white" />
        </LinearLayout>
    </LinearLayout>

    <include layout="@layout/view_player_bar" />

    <!-- Question content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/question_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/question_progress_initial"
            android:textColor="@color/background_light"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="@color/background"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/question_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:text="@string/sample_question"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center" />
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/answer_a"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/answer_a"
            android:textColor="@color/primary"
            android:backgroundTint="@color/background_light"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/answer_b"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/answer_b"
            android:textColor="@color/primary"
            android:backgroundTint="@color/background_light"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/answer_c"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/answer_c"
            android:textColor="@color/primary"
            android:backgroundTint="@color/background_light"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/answer_d"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/answer_d"
            android:textColor="@color/primary"
            android:backgroundTint="@color/background_light" />
    </LinearLayout>

    <!-- Feedback o ishodu pitanja (igrač + protivnik) -->
    <TextView
        android:id="@+id/feedback_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="40dp"
        android:gravity="center"
        android:textSize="14sp"
        android:textColor="@color/white"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp" />

    <!-- Score -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center"
        android:background="@color/primary_dark">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/you_score_label"
            android:textSize="16sp"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/score_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/score_zero"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/warning"
            android:layout_marginStart="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/opponent_score_label"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:layout_marginStart="24dp" />

        <TextView
            android:id="@+id/opponent_score_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/score_zero"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/warning"
            android:layout_marginStart="8dp" />
    </LinearLayout>
</LinearLayout>
