<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary">

    <!-- Header: quit | remaining time (center) | score -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <Button
            android:id="@+id/quit_button"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="@string/close_symbol"
            android:textSize="22sp"
            android:textColor="@color/white"
            android:background="?attr/selectableItemBackground" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/remaining_time_label"
                android:textSize="11sp"
                android:textColor="@color/background_light" />

            <TextView
                android:id="@+id/timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/time_60s"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/white" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/header_chip"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/score_label"
                android:textSize="10sp"
                android:textColor="@color/background_light" />

            <TextView
                android:id="@+id/score_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/score_zero"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/warning" />
        </LinearLayout>

    </RelativeLayout>

    <!-- Game Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/background_light"
        android:clipToPadding="false"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Round / phase banner -->
            <TextView
                android:id="@+id/status_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/mb_phase_target"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:padding="10dp"
                android:background="@color/background"
                android:layout_marginBottom="12dp" />

            <!-- Target Number Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@color/background"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/target_number"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/target_number"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mb_hidden"
                        android:textSize="44sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- STOP button (reveals target, then numbers; also via shake) -->
            <Button
                android:id="@+id/stop_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/mb_stop_show_target"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/accent"
                android:layout_marginBottom="20dp" />

            <!-- Given Numbers -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/given_numbers"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <GridLayout
                android:id="@+id/numbers_grid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:rowCount="2"
                android:layout_marginBottom="20dp">

                <Button
                    android:layout_width="0dp"
                    android:layout_height="68dp"
                    android:layout_columnWeight="1"
                    android:text="@string/number_25"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primary"
                    android:layout_margin="5dp" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="68dp"
                    android:layout_columnWeight="1"
                    android:text="@string/number_50"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primary"
                    android:layout_margin="5dp" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="68dp"
                    android:layout_columnWeight="1"
                    android:text="@string/number_3"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primary"
                    android:layout_margin="5dp" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="68dp"
                    android:layout_columnWeight="1"
                    android:text="@string/number_7"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primary"
                    android:layout_margin="5dp" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="68dp"
                    android:layout_columnWeight="1"
                    android:text="@string/number_2"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primary"
                    android:layout_margin="5dp" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="68dp"
                    android:layout_columnWeight="1"
                    android:text="@string/number_9"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primary"
                    android:layout_margin="5dp" />
            </GridLayout>

            <!-- Operators -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/operators_label"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <GridLayout
                android:id="@+id/operators_grid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:rowCount="2"
                android:layout_marginBottom="20dp">

                <Button
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:layout_gravity="fill_horizontal"
                    android:minWidth="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:text="@string/op_paren_open"
                    android:textSize="24sp"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primary_dark"
                    android:layout_margin="4dp" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:layout_gravity="fill_horizontal"
                    android:minWidth="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:text="@string/op_paren_close"
                    android:textSize="24sp"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primary_dark"
                    android:layout_margin="4dp" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:layout_gravity="fill_horizontal"
                    android:minWidth="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:text="@string/op_plus"
                    android:textSize="24sp"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primary_dark"
                    android:layout_margin="4dp" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:layout_gravity="fill_horizontal"
                    android:minWidth="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:text="@string/op_minus"
                    android:textSize="24sp"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primary_dark"
                    android:layout_margin="4dp" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:layout_gravity="fill_horizontal"
                    android:minWidth="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:text="@string/op_mul"
                    android:textSize="24sp"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primary_dark"
                    android:layout_margin="4dp" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:layout_gravity="fill_horizontal"
                    android:minWidth="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:text="@string/op_div"
                    android:textSize="24sp"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primary_dark"
                    android:layout_margin="4dp" />
            </GridLayout>

            <!-- Expression Display -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/expression_label"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/expression_display"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="52dp"
                android:text="@string/expr_placeholder"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:background="@drawable/edit_text_background"
                android:padding="14dp"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical" />

            <!-- Backspace + Clear -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/backspace_button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/backspace_label"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/divider"
                    android:layout_marginEnd="6dp" />

                <Button
                    android:id="@+id/clear_button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/clear_label"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/divider" />
            </LinearLayout>

            <!-- Result Display -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/result"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/result_display"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="52dp"
                android:text="@string/result_placeholder"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:background="@drawable/edit_text_background"
                android:padding="14dp"
                android:layout_marginBottom="20dp"
                android:gravity="center_vertical" />

            <!-- Submit Button -->
            <Button
                android:id="@+id/submit_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/submit"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/success"
                android:layout_marginBottom="48dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
