<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary">

    <!-- Header with Timer and Score -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/quit_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="@string/close_symbol"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/game_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/moj_broj"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/time_label"
                android:textSize="12sp"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/time_60s"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

        </LinearLayout>

    </LinearLayout>

    <!-- Game Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Target Number -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@color/background"
                android:layout_marginBottom="16dp"
                android:gravity="center">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/target_number"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/target_number"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/target_number_value_sample"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:gravity="center" />

            </LinearLayout>

            <!-- Given Numbers -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/given_numbers"
                android:textSize="14sp"
                android:textColor="@color/background_light"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sample_numbers"
                android:textSize="12sp"
                android:textColor="@color/background_light"
                android:layout_marginBottom="8dp" />

            <GridLayout
                android:id="@+id/numbers_grid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="6"
                android:rowCount="1"
                android:layout_marginBottom="24dp">

                <Button
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="@string/number_25"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/background"
                    android:layout_margin="4dp" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="@string/number_50"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/background"
                    android:layout_margin="4dp" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="@string/number_3"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/background"
                    android:layout_margin="4dp" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="@string/number_7"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/background"
                    android:layout_margin="4dp" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="@string/number_2"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/background"
                    android:layout_margin="4dp" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="@string/number_9"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/background"
                    android:layout_margin="4dp" />

            </GridLayout>

            <!-- Operators -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/operators_label"
                android:textSize="14sp"
                android:textColor="@color/background_light"
                android:layout_marginBottom="8dp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:rowCount="2"
                android:layout_marginBottom="24dp">

                <Button
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:text="@string/op_paren_open"
                    android:textSize="20sp"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primary_dark"
                    android:layout_margin="4dp" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:text="@string/op_paren_close"
                    android:textSize="20sp"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primary_dark"
                    android:layout_margin="4dp" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:text="@string/op_plus"
                    android:textSize="20sp"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primary_dark"
                    android:layout_margin="4dp" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:text="@string/op_minus"
                    android:textSize="20sp"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primary_dark"
                    android:layout_margin="4dp" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:text="@string/op_mul"
                    android:textSize="20sp"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primary_dark"
                    android:layout_margin="4dp" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:text="@string/op_div"
                    android:textSize="20sp"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primary_dark"
                    android:layout_margin="4dp" />

            </GridLayout>

            <!-- Expression Display -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/expression_label"
                android:textSize="14sp"
                android:textColor="@color/background_light"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/expression_display"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/expr_placeholder"
                android:textColor="@color/text_primary"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical" />

            <!-- Result Display -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/result"
                android:textSize="14sp"
                android:textColor="@color/background_light"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/result_display"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/result_placeholder"
                android:textColor="@color/text_primary"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="24dp"
                android:gravity="center_vertical" />

            <!-- Submit Button -->
            <Button
                android:id="@+id/submit_button"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/submit"
                android:textSize="16sp"
                android:textColor="@color/primary"
                android:backgroundTint="@color/background_light" />

        </LinearLayout>

    </ScrollView>

    <!-- Score Display -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center"
        android:background="@color/primary_dark">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/score_label"
            android:textSize="16sp"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/score_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/score_zero"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/warning"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</LinearLayout>








