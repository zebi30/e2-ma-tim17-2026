<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="@color/primary"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/profile"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/logout_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/logout"
                android:textColor="@color/primary"
                android:backgroundTint="@color/white" />
        </LinearLayout>

        <!-- Avatar Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <!-- Avatar with frame -->
                <FrameLayout
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:background="@color/league_gold"
                    android:padding="6dp">

                    <TextView
                        android:id="@+id/avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="@string/avatar_placeholder"
                        android:textSize="64sp"
                        android:gravity="center"
                        android:background="@color/background_light" />
                </FrameLayout>

                <Button
                    android:id="@+id/change_avatar_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/change_avatar"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primary"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:id="@+id/username_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sample_username"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:id="@+id/email_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sample_email"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Stats row: tokens / stars -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tokens_label"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tokens_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sample_tokens"
                        android:textColor="@color/primary"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stars_label"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/stars_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sample_stars"
                        android:textColor="@color/warning"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- League / Region / QR -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/league_icon"
                        android:textSize="20sp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/league_label"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/league_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sample_league"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/region_label"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/region_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sample_region"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/qr_code_label"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="8dp" />

                <ImageView
                    android:id="@+id/qr_image"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:contentDescription="@string/qr_code_label"
                    android:background="@color/white"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Statistics -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/statistics"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/stat_avg_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_avg_points"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/stat_kzz_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_kzz"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/stat_moj_broj_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_moj_broj"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/stat_korak_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_korak"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/stat_asocijacije_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_asocijacije"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/stat_skocko_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_skocko"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/stat_spojnice_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_spojnice"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/stat_total_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_total_games"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/stat_win_loss_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_win_loss"
                    android:textColor="@color/text_primary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
