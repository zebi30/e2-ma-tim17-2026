<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical"
	android:background="@color/primary">

	<!-- Header with Timer and Attempts -->
	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="horizontal"
		android:padding="16dp"
		android:gravity="center_vertical">

		<Button
			android:id="@+id/quit_button"
			android:layout_width="48dp"
			android:layout_height="48dp"
			android:text="@string/close_symbol"
			android:textSize="24sp"
			android:textColor="@color/white"
			android:background="?attr/selectableItemBackground" />

		<TextView
			android:id="@+id/game_title"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:layout_weight="1"
			android:text="@string/skocko"
			android:textSize="20sp"
			android:textStyle="bold"
			android:textColor="@color/white"
			android:gravity="center" />

		<LinearLayout
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:gravity="end">

				<TextView
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/time_label"
					android:textSize="12sp"
					android:textColor="@color/white" />

			<TextView
				android:id="@+id/timer"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="@string/time_30s"
				android:textSize="18sp"
				android:textStyle="bold"
				android:textColor="@color/white" />

		</LinearLayout>

	</LinearLayout>

	<!-- Game Content -->
	<ScrollView
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:layout_weight="1"
		android:padding="16dp">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical">

			<!-- Attempt Info -->
			<TextView
				android:id="@+id/attempt_text"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="@string/attempt_initial"
				android:textSize="16sp"
				android:textColor="@color/background_light"
				android:gravity="center"
				android:layout_marginBottom="16dp" />

			<!-- Target Pattern -->
			<com.google.android.material.card.MaterialCardView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="24dp"
				app:cardCornerRadius="12dp"
				app:cardBackgroundColor="@color/background">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical"
					android:padding="20dp"
					android:gravity="center">

								<TextView
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:text="@string/skocko_target_label"
									android:textSize="14sp"
									android:textStyle="bold"
									android:textColor="@color/text_secondary"
									android:layout_marginBottom="12dp" />

					<LinearLayout
						android:id="@+id/target_pattern"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:orientation="horizontal"
						android:gravity="center">

						<TextView
							android:layout_width="48dp"
							android:layout_height="48dp"
							android:layout_margin="4dp"
							android:gravity="center"
							android:text="@string/skocko_placeholder"
							android:textSize="20sp"
							android:textStyle="bold"
							android:textColor="@color/primary"
							android:background="@android:drawable/btn_default" />

						<TextView
							android:layout_width="48dp"
							android:layout_height="48dp"
							android:layout_margin="4dp"
							android:gravity="center"
							android:text="@string/skocko_placeholder"
							android:textSize="20sp"
							android:textStyle="bold"
							android:textColor="@color/primary"
							android:background="@android:drawable/btn_default" />

						<TextView
							android:layout_width="48dp"
							android:layout_height="48dp"
							android:layout_margin="4dp"
							android:gravity="center"
							android:text="@string/skocko_placeholder"
							android:textSize="20sp"
							android:textStyle="bold"
							android:textColor="@color/primary"
							android:background="@android:drawable/btn_default" />

						<TextView
							android:layout_width="48dp"
							android:layout_height="48dp"
							android:layout_margin="4dp"
							android:gravity="center"
							android:text="@string/skocko_placeholder"
							android:textSize="20sp"
							android:textStyle="bold"
							android:textColor="@color/primary"
							android:background="@android:drawable/btn_default" />

					</LinearLayout>

				</LinearLayout>

			</com.google.android.material.card.MaterialCardView>

			<!-- Symbol Grid -->
			<TextView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="@string/skocko_symbols"
				android:textSize="14sp"
				android:textColor="@color/background_light"
				android:layout_marginBottom="8dp" />

			<GridLayout
				android:id="@+id/symbols_grid"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:columnCount="3"
				android:rowCount="2"
				android:layout_marginBottom="24dp">

				<Button
					android:layout_width="0dp"
					android:layout_height="72dp"
					android:layout_columnWeight="1"
					android:layout_margin="6dp"
					android:text="@string/symbol_star"
					android:textSize="28sp"
					android:textStyle="bold"
					android:textColor="@color/white"
					android:backgroundTint="@color/primary_dark" />

				<Button
					android:layout_width="0dp"
					android:layout_height="72dp"
					android:layout_columnWeight="1"
					android:layout_margin="6dp"
					android:text="@string/symbol_circle"
					android:textSize="28sp"
					android:textStyle="bold"
					android:textColor="@color/white"
					android:backgroundTint="@color/primary_dark" />

				<Button
					android:layout_width="0dp"
					android:layout_height="72dp"
					android:layout_columnWeight="1"
					android:layout_margin="6dp"
					android:text="@string/symbol_diamond"
					android:textSize="28sp"
					android:textStyle="bold"
					android:textColor="@color/white"
					android:backgroundTint="@color/primary_dark" />

				<Button
					android:layout_width="0dp"
					android:layout_height="72dp"
					android:layout_columnWeight="1"
					android:layout_margin="6dp"
					android:text="@string/symbol_heart"
					android:textSize="28sp"
					android:textStyle="bold"
					android:textColor="@color/white"
					android:backgroundTint="@color/primary_dark" />

				<Button
					android:layout_width="0dp"
					android:layout_height="72dp"
					android:layout_columnWeight="1"
					android:layout_margin="6dp"
					android:text="@string/symbol_triangle"
					android:textSize="28sp"
					android:textStyle="bold"
					android:textColor="@color/white"
					android:backgroundTint="@color/primary_dark" />

				<Button
					android:layout_width="0dp"
					android:layout_height="72dp"
					android:layout_columnWeight="1"
					android:layout_margin="6dp"
					android:text="@string/symbol_sun"
					android:textSize="28sp"
					android:textStyle="bold"
					android:textColor="@color/white"
					android:backgroundTint="@color/primary_dark" />

			</GridLayout>

			<!-- Guess History -->
			<TextView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="@string/attempts_label"
				android:textSize="14sp"
				android:textColor="@color/background_light"
				android:layout_marginBottom="8dp" />

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="vertical"
				android:layout_marginBottom="24dp">

				<TextView
					android:layout_width="match_parent"
					android:layout_height="48dp"
					android:layout_marginBottom="8dp"
					android:gravity="center_vertical"
					android:paddingStart="16dp"
					android:paddingEnd="16dp"
					android:text="@string/attempt_1"
					android:textColor="@color/text_primary"
					android:background="@color/background" />

				<TextView
					android:layout_width="match_parent"
					android:layout_height="48dp"
					android:layout_marginBottom="8dp"
					android:gravity="center_vertical"
					android:paddingStart="16dp"
					android:paddingEnd="16dp"
					android:text="@string/attempt_2"
					android:textColor="@color/text_primary"
					android:background="@color/background" />

				<TextView
					android:layout_width="match_parent"
					android:layout_height="48dp"
					android:layout_marginBottom="8dp"
					android:gravity="center_vertical"
					android:paddingStart="16dp"
					android:paddingEnd="16dp"
					android:text="@string/attempt_3"
					android:textColor="@color/text_primary"
					android:background="@color/background" />

				<TextView
					android:layout_width="match_parent"
					android:layout_height="48dp"
					android:layout_marginBottom="8dp"
					android:gravity="center_vertical"
					android:paddingStart="16dp"
					android:paddingEnd="16dp"
					android:text="@string/attempt_4"
					android:textColor="@color/text_primary"
					android:background="@color/background" />

				<TextView
					android:layout_width="match_parent"
					android:layout_height="48dp"
					android:layout_marginBottom="8dp"
					android:gravity="center_vertical"
					android:paddingStart="16dp"
					android:paddingEnd="16dp"
					android:text="@string/attempt_5"
					android:textColor="@color/text_primary"
					android:background="@color/background" />

				<TextView
					android:layout_width="match_parent"
					android:layout_height="48dp"
					android:gravity="center_vertical"
					android:paddingStart="16dp"
					android:paddingEnd="16dp"
					android:text="@string/attempt_6"
					android:textColor="@color/text_primary"
					android:background="@color/background" />

			</LinearLayout>

			<!-- Action Button -->
			<Button
				android:id="@+id/submit_button"
				android:layout_width="match_parent"
				android:layout_height="48dp"
				android:text="@string/submit"
				android:textSize="16sp"
				android:textColor="@color/primary"
				android:backgroundTint="@color/background_light" />

		</LinearLayout>

	</ScrollView>

</LinearLayout>





